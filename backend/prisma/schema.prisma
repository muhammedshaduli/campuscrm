generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  ACCOUNTANT
  SALES
}

enum LeadStatus {
  NEW_ENQUIRY
  COUNSELING
  INTERESTED
  NOT_INTERESTED
  ADMISSION_CONFIRMED
  NOT_ATTENDED
}

enum CallStatus {
  PENDING
  CALLED
  FOLLOWUP_NEEDED
  NOT_ATTENDED
  CLOSED
}

enum LeadSource {
  WEBSITE
  WALK_IN
  WHATSAPP
  INSTAGRAM
  FACEBOOK_ADS
  GOOGLE_ADS
  REFERRAL
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model User {
  id                String         @id @default(uuid())
  userCode          String?        @unique
  fullName          String
  email             String         @unique
  phone             String?
  username          String?        @unique
  passwordHash      String
  role              Role           @default(SALES)
  designation       String?
  departmentId      String?
  department        Department?    @relation(fields: [departmentId], references: [id])
  branchId          String?
  branch            Branch?        @relation(fields: [branchId], references: [id])
  reportingManagerId String?
  reportingManager  User?          @relation("ManagerToSubordinate", fields: [reportingManagerId], references: [id])
  subordinates      User[]         @relation("ManagerToSubordinate")
  
  isActive          Boolean        @default(true)
  isSuspended       Boolean        @default(false)
  lastLoginAt       DateTime?
  createdBy         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  assignedLeads     Lead[]         @relation("AssignedCounsellor")
  createdLeads      Lead[]         @relation("LeadCreator")
  followups         LeadFollowup[]
  reminders         Reminder[]
  activities        Activity[]
  invoices          Invoice[]
  payments          Payment[]      @relation("Collector")
  tokens            RefreshToken[]
  
  permissionOverrides UserPermissionOverride[]
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        String   @id @default(uuid())
  name      String   @unique
  location  String?
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPermissionOverride {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    String
  action    String
  allowed   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model State {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  districts District[]
  leads     Lead[]
  colleges  College[]
}

model District {
  id        Int       @id @default(autoincrement())
  name      String
  stateId   Int
  state     State     @relation(fields: [stateId], references: [id])
  leads     Lead[]
  colleges  College[]

  @@unique([name, stateId])
}

model College {
  id           String   @id @default(uuid())
  name         String
  stateId      Int
  state        State    @relation(fields: [stateId], references: [id])
  districtId   Int?
  district     District? @relation(fields: [districtId], references: [id])
  address      String?
  contactEmail String?
  contactPhone String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  leads        Lead[]
}

model Course {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  duration    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leads       Lead[]
}

model Lead {
  id                  String         @id @default(uuid())
  leadCode            String         @unique
  studentName         String
  phone               String
  whatsappNumber      String?
  dob                 DateTime?
  email               String?
  area                String?
  districtId          Int?
  district            District?      @relation(fields: [districtId], references: [id])
  stateId             Int?
  state               State?         @relation(fields: [stateId], references: [id])
  preferredCourseId   String?
  preferredCourse     Course?        @relation(fields: [preferredCourseId], references: [id])
  collegeId           String?
  college             College?       @relation(fields: [collegeId], references: [id])
  source              LeadSource     @default(WEBSITE)
  assignedCounsellorId String?
  assignedCounsellor  User?          @relation("AssignedCounsellor", fields: [assignedCounsellorId], references: [id])
  status              LeadStatus     @default(NEW_ENQUIRY)
  callStatus          CallStatus     @default(PENDING)
  lastCallDate        DateTime?
  nextCallDate        DateTime?
  notAttended         Boolean        @default(false)
  callAttempts        Int            @default(0)
  priority            Priority       @default(MEDIUM)
  notes               String?
  createdBy           String?
  creator             User?          @relation("LeadCreator", fields: [createdBy], references: [id])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  
  followups           LeadFollowup[]
  reminders           Reminder[]
  activities          Activity[]
  invoices            Invoice[]
  
  @@index([status])
  @@index([source])
  @@index([nextCallDate])
  @@index([assignedCounsellorId])
}

model LeadFollowup {
  id             String     @id @default(uuid())
  leadId         String
  lead           Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  counsellorId   String
  counsellor     User       @relation(fields: [counsellorId], references: [id])
  followupDate   DateTime   @default(now())
  nextCallDate   DateTime?
  callStatus     CallStatus
  leadStatus     LeadStatus
  notes          String?
  notAttended    Boolean    @default(false)
  createdAt      DateTime   @default(now())
}

model Reminder {
  id          String   @id @default(uuid())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  assignedTo  String
  user        User     @relation(fields: [assignedTo], references: [id])
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  priority    Priority @default(MEDIUM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Activity {
  id         String   @id @default(uuid())
  type       String
  entityType String
  entityId   String?
  message    String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  metadata   Json?
  createdAt  DateTime @default(now())
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  leadId        String?
  lead          Lead?         @relation(fields: [leadId], references: [id])
  studentName   String
  amount        Decimal       @db.Decimal(10, 2)
  dueDate       DateTime
  status        String        @default("Pending")
  notes         String?
  createdBy     String
  creator       User          @relation(fields: [createdBy], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  items         InvoiceItem[]
  payments      Payment[]
}

model InvoiceItem {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  amount    Decimal @db.Decimal(10, 2)
}

model Payment {
  id              String   @id @default(uuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id])
  amount          Decimal  @db.Decimal(10, 2)
  paymentDate     DateTime @default(now())
  paymentMethod   String
  referenceNumber String?
  notes           String?
  receivedBy      String
  collector       User     @relation("Collector", fields: [receivedBy], references: [id])
  createdAt       DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  table     String
  recordId  String
  oldData   Json?
  newData   Json?
  userId    String?
  createdAt DateTime @default(now())
}
